generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  FACULTY
  ADMIN
}

enum SubmissionType {
  WEEKLY
  FINAL
  IEEE
  LITERATURE
}

enum SubmissionStatus {
  DRAFT
  PENDING_REVIEW
  UNDER_REVIEW
  APPROVED
  REVISION_REQUIRED
  REJECTED
}

enum ProjectStatus {
  DISCOVERY
  RESEARCH
  EXECUTION
  EVALUATION
  COMPLETED
  ON_HOLD
}

enum HealthStatus {
  LOW
  MEDIUM
  HIGH
}

enum ReviewDecision {
  APPROVED
  REVISION_REQUIRED
  REJECTED
  ESCALATED
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ProblemSource {
  FACULTY
  INDUSTRY
  RESEARCH_LAB
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

model User {
  id                   String            @id @default(cuid())
  name                 String
  email                String            @unique
  passwordHash         String
  role                 Role              @default(STUDENT)
  avatar               String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  taughtTeams          Team[]            @relation("FacultyTeams")
  memberships          TeamMember[]
  performance          Performance?
  achievements         Achievement[]
  submittedSubmissions Submission[]      @relation("SubmittedBy")
  reviewedSubmissions  Submission[]      @relation("ReviewedBy")
  reviewEntries        Review[]          @relation("ReviewAuthor")
  bookmarks            ProblemBookmark[]
  createdProblems      Problem[]         @relation("ProblemCreator")
  activityEvents       ActivityEvent[]

  @@index([role])
}

model Team {
  id            String          @id @default(cuid())
  name          String
  batch         String
  projectTitle  String
  facultyId     String
  projectId     String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  faculty       User            @relation("FacultyTeams", fields: [facultyId], references: [id], onDelete: Restrict)
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  students      TeamMember[]
  submissions   Submission[]
  activityEvents ActivityEvent[]

  @@index([facultyId])
  @@index([batch])
}

model TeamMember {
  id                String    @id @default(cuid())
  teamId            String
  userId            String
  roleLabel         String    @default("Member")
  contributionScore Int       @default(0)
  lastActiveAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  team              Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model Problem {
  id                   String            @id @default(cuid())
  title                String
  summary              String
  description          String
  category             String
  domain               String
  difficulty           DifficultyLevel
  source               ProblemSource
  trendingScore        Int               @default(0)
  isFacultyRecommended Boolean           @default(false)
  createdById          String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  createdBy            User?             @relation("ProblemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  bookmarks            ProblemBookmark[]
  projects             Project[]

  @@index([category])
  @@index([domain])
  @@index([difficulty])
  @@index([source])
  @@index([trendingScore])
}

model Project {
  id             String             @id @default(cuid())
  title          String
  description    String
  domain         String
  difficulty     DifficultyLevel
  status         ProjectStatus      @default(DISCOVERY)
  progress       Int                @default(0)
  riskScore      Int                @default(0)
  healthStatus   HealthStatus       @default(LOW)
  problemId      String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  problem        Problem?           @relation(fields: [problemId], references: [id], onDelete: SetNull)
  team           Team?
  milestones     ProjectMilestone[]
  analytics      AnalyticsSnapshot[]
  activityEvents ActivityEvent[]

  @@index([status])
  @@index([healthStatus])
  @@index([riskScore])
}

model ProjectMilestone {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  description String?
  stage       String
  status      MilestoneStatus @default(PENDING)
  dueAt       DateTime?
  completedAt DateTime?
  position    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([stage])
  @@index([status])
}

model Submission {
  id           String           @id @default(cuid())
  teamId        String
  submittedById String?
  reviewedById  String?
  type          SubmissionType
  title         String
  content       String
  status        SubmissionStatus @default(PENDING_REVIEW)
  submittedAt   DateTime         @default(now())
  reviewedAt    DateTime?
  feedback      String?
  score         Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  team          Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  submittedBy   User?            @relation("SubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  reviewedBy    User?            @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviews       Review[]

  @@index([teamId])
  @@index([status])
  @@index([type])
}

model Review {
  id         String         @id @default(cuid())
  submissionId String
  reviewerId String
  score      Int
  comments   String
  decision   ReviewDecision
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  submission Submission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer   User           @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([reviewerId])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  badge       String
  points      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Performance {
  id              String   @id @default(cuid())
  userId          String   @unique
  score           Int      @default(0)
  attendanceScore Int      @default(0)
  submissionScore Int      @default(0)
  reviewScore     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProblemBookmark {
  id        String   @id @default(cuid())
  problemId String
  userId    String
  createdAt DateTime @default(now())
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([problemId, userId])
  @@index([userId])
}

model AnalyticsSnapshot {
  id                   String   @id @default(cuid())
  projectId            String
  label                String
  sequence             Int
  literatureProgress   Int      @default(0)
  experimentationProgress Int   @default(0)
  writingProgress      Int      @default(0)
  submittedCount       Int      @default(0)
  reviewedCount        Int      @default(0)
  escalatedCount       Int      @default(0)
  plannedPoints        Int      @default(0)
  deliveredPoints      Int      @default(0)
  openBacklogCount     Int      @default(0)
  criticalBacklogCount Int      @default(0)
  clearedBacklogCount  Int      @default(0)
  performanceScore     Int      @default(0)
  targetScore          Int      @default(0)
  createdAt            DateTime @default(now())
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sequence])
  @@index([projectId])
}

model ActivityEvent {
  id        String   @id @default(cuid())
  teamId     String?
  projectId  String?
  userId     String?
  type      String
  title     String
  detail    String
  createdAt DateTime @default(now())
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}
