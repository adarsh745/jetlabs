// Syntra Platform — Prisma Schema
// PostgreSQL database schema for academic execution OS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  STUDENT
  FACULTY
  ADMIN
}

enum ProjectStatus {
  ON_TRACK
  DELAYED
  INACTIVE
  AT_RISK
}

enum PaperStatus {
  NOT_STARTED
  DRAFTING
  UNDER_REVIEW
  APPROVED
  PUBLISHED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BacklogStatus {
  PENDING
  CLEARED
}

enum AchievementLevel {
  COLLEGE
  STATE
  NATIONAL
  INTERNATIONAL
}

enum NotificationType {
  INFO
  WARNING
  ACTION
  REVIEW
}

// ─── Auth (BetterAuth-compatible) ────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  emailVerified Boolean   @default(false)
  role          UserRole  @default(STUDENT)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions       Session[]
  studentProfile StudentProfile?
  facultyProfile FacultyProfile?
  notifications  Notification[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

// ─── Academic Profiles ───────────────────────────────────

model StudentProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  rollNumber        String    @unique
  department        String
  section           String
  batch             String
  year              String
  phone             String?
  parentPhone       String?
  address           String?
  dob               DateTime?
  cgpa              Float     @default(0)
  semester          Int       @default(1)
  skills            String[]  @default([])
  interests         String[]  @default([])
  certifications    String[]  @default([])
  internshipStatus  String    @default("None")
  attendanceOverall Float     @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMemberships TeamMember[]
  submissions     Submission[]
  backlogs        Backlog[]
  achievements    Achievement[]
  kpis            KPI[]

  @@index([department])
  @@index([batch])
  @@index([rollNumber])
  @@map("student_profiles")
}

model FacultyProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  department      String
  designation     String?
  specializations String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentorTeams Team[]   @relation("TeamMentor")
  reviews     Review[]

  @@index([department])
  @@map("faculty_profiles")
}

// ─── Projects & Teams ────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  title         String
  description   String?
  domain        String
  status        ProjectStatus @default(ON_TRACK)
  paperStatus   PaperStatus   @default(NOT_STARTED)
  paperProgress Float         @default(0)
  startDate     DateTime      @default(now())
  endDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  team      Team?
  roadmap   Roadmap?
  tasks     Task[]
  analytics AnalyticsSnapshot[]

  @@index([status])
  @@index([domain])
  @@map("projects")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  batch     String
  projectId String   @unique
  mentorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mentor  FacultyProfile @relation("TeamMentor", fields: [mentorId], references: [id])
  members TeamMember[]

  @@index([batch])
  @@index([mentorId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  studentId String
  role      String   @default("Member")
  joinedAt  DateTime @default(now())

  team    Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([teamId, studentId])
  @@map("team_members")
}

// ─── Execution Tracking ──────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  week        Int?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([week])
  @@map("tasks")
}

model Roadmap {
  id          String   @id @default(cuid())
  projectId   String   @unique
  title       String
  totalWeeks  Int      @default(8)
  currentWeek Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestones Milestone[]

  @@map("roadmaps")
}

model Milestone {
  id           String   @id @default(cuid())
  roadmapId    String
  week         Int
  label        String
  description  String?
  state        String   @default("todo") // done | current | todo
  deliverables String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([roadmapId, week])
  @@index([roadmapId])
  @@map("milestones")
}

model Submission {
  id          String           @id @default(cuid())
  studentId   String
  week        Int
  title       String
  summary     String
  githubUrl   String?
  deployUrl   String?
  status      SubmissionStatus @default(PENDING)
  attachments String[]         @default([])
  submittedAt DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  review  Review?

  @@index([studentId])
  @@index([status])
  @@index([week])
  @@map("submissions")
}

model Review {
  id           String   @id @default(cuid())
  submissionId String   @unique
  facultyId    String
  comment      String
  score        Float?
  reviewedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission Submission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  faculty    FacultyProfile @relation(fields: [facultyId], references: [id])

  @@index([facultyId])
  @@map("reviews")
}

// ─── KPI & Analytics ─────────────────────────────────────

model KPI {
  id         String   @id @default(cuid())
  studentId  String
  metric     String // e.g. "attendance", "submission_rate", "paper_progress"
  value      Float
  week       Int?
  semester   Int?
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, metric])
  @@index([week])
  @@map("kpis")
}

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  projectId   String
  week        Int
  progress    Float    @default(0)
  paper       Float    @default(0)
  submissions Int      @default(0)
  approved    Int      @default(0)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, week])
  @@index([projectId])
  @@map("analytics_snapshots")
}

// ─── Academics ───────────────────────────────────────────

model Backlog {
  id           String        @id @default(cuid())
  studentId    String
  subject      String
  code         String
  semester     Int
  attempts     Int           @default(1)
  status       BacklogStatus @default(PENDING)
  internal     Float?
  external     Float?
  total        Float?
  academicYear String?
  dateCleared  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@map("backlogs")
}

model Achievement {
  id          String           @id @default(cuid())
  studentId   String
  kind        String // "academic" | "non-academic"
  title       String
  category    String
  description String
  date        DateTime
  level       AchievementLevel
  role        String?
  event       String?
  verified    Boolean          @default(false)
  certificate String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([level])
  @@map("achievements")
}

// ─── Notifications ───────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(INFO)
  title     String
  message   String
  read      Boolean          @default(false)
  actionUrl String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}
