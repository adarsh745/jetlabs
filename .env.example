# Syntra Platform environment variables
# Copy this to .env.local and fill in the values.

# Neon PostgreSQL
# Use a pooled Neon connection string here (hostname includes "-pooler").
DATABASE_URL="postgresql://user:password@ep-example-pooler.ap-southeast-1.aws.neon.tech/syntra?sslmode=require"

# Use the direct Neon connection string here for Prisma CLI commands.
DIRECT_URL="postgresql://user:password@ep-example.ap-southeast-1.aws.neon.tech/syntra?sslmode=require"

# Authentication
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_COOKIE_NAME="syntra.session"
AUTH_SESSION_MAX_AGE_SECONDS="604800"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Syntra"

# Optional bootstrap admin account for `npm run db:seed`
SEED_ADMIN_NAME="Syntra Administrator"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123"
