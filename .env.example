# Syntra Platform environment variables
# Copy this to .env.local and fill in the values.

# PostgreSQL
# Use the pooled connection for the application runtime.
DATABASE_URL="postgresql://user:password@ep-example-pooler.us-east-1.aws.neon.tech/syntra?sslmode=require"

# Use the direct connection for Prisma CLI operations.
DIRECT_URL="postgresql://user:password@ep-example.us-east-1.aws.neon.tech/syntra?sslmode=require"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Syntra"

# Seed defaults
SEED_ADMIN_EMAIL="admin@syntra.edu"
